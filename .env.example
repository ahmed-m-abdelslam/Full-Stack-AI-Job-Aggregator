# Database
DATABASE_URL=postgresql://jobuser:jobpassword@localhost:5432/ai_jobs_db

# OpenAI
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Scraping
SCRAPE_INTERVAL_HOURS=6
REQUEST_DELAY_SECONDS=2
SELENIUM_HEADLESS=true

# ====== فلاتر السحب — الجديدة ======

# البلد أو البلدان (مفصولين بفاصلة)
# أمثلة: "Egypt" أو "Egypt,UAE,Saudi Arabia" أو "United States,United Kingdom"
TARGET_COUNTRIES=Egypt

# عدد الأيام اللي فاتت (آخر كام يوم)
SCRAPE_DAYS_BACK=7

# أو تحديد تاريخ محدد بداية ونهاية (اختياري — لو حددتهم هيتجاهل DAYS_BACK)
# SCRAPE_DATE_FROM=2025-03-01
# SCRAPE_DATE_TO=2025-03-09

# الحد الأقصى للوظائف لكل مصدر/كلمة بحث (يوفر وقت وفلوس API)
MAX_JOBS_PER_SOURCE=50

# ====================================

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2
DUPLICATE_SIMILARITY_THRESHOLD=0.92

# Web App
DASH_HOST=0.0.0.0
DASH_PORT=8050
DASH_DEBUG=true